{
  "openapi": "3.1.1",
  "info": {
    "title": "VectorSearch.Api | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5004"
    }
  ],
  "paths": {
    "/upload": {
      "post": {
        "tags": [
          "VectorSearch.Api"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/search": {
      "post": {
        "tags": [
          "VectorSearch.Api"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SearchRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          }
        }
      },
      "UploadRequest": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "vector": {
            "type": "array",
            "items": {
              "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
              "type": [
                "number",
                "string"
              ],
              "format": "float"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "VectorSearch.Api"
    }
  ]
}